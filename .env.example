# API
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/office_assistance

# Required: at least 32 random bytes (HS256 signing for local user sessions)
AUTH_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# CORS: comma-separated origins allowed to call the API
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

PORT=4000
RATE_LIMIT_MAX=200
NODE_ENV=development

# Optional seed passwords (defaults in seed.ts if unset)
# SEED_LEAD_PASSWORD=
# SEED_ASSISTANT_PASSWORD=
# SEED_DEV_PASSWORD=   # extra seeded devs (backend@, qa@, web@, mobile@local.dev)

# Optional: Microsoft 365 (used when the database M365 app settings row is empty; team lead can set IDs in the web UI "App registration" instead)
# M365_TENANT_ID=
# M365_CLIENT_ID=
# VITE_API_BASE_URL=http://localhost:4000

# Docker build: set to 0 if `npm ci` in the image fails with SELF_SIGNED_CERT_IN_CHAIN (or add docker/corporate-ca.pem)
# NPM_STRICT_SSL=1
