{
  "name": "office-assistance",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @office/web",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w @office/api\" \"npm run dev -w @office/web\"",
    "build": "npm run build -w @office/types && npm run build -w @office/api && npm run build -w @office/web",
    "lint": "npm run lint -ws --if-present",
    "db:migrate": "npm run prisma:migrate -w @office/api",
    "db:generate": "npm run prisma:generate -w @office/api",
    "db:seed": "npm run db:seed -w @office/api",
    "docker:up": "docker compose up --build -d",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
